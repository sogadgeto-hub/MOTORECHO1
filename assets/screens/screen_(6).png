<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>MotorEcho | Vehicle Profile</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-primary-fixed-variant": "#004f54",
                    "surface-container-low": "#151d1e",
                    "primary-container": "#00f2ff",
                    "on-primary-fixed": "#002022",
                    "tertiary-fixed": "#ffe173",
                    "primary": "#e1fdff",
                    "error": "#ffb4ab",
                    "on-surface-variant": "#b9cacb",
                    "on-background": "#dce4e4",
                    "secondary-container": "#056ced",
                    "outline-variant": "#3a494b",
                    "surface-container": "#192122",
                    "surface-bright": "#333b3b",
                    "on-secondary-fixed": "#001944",
                    "on-primary-container": "#006a71",
                    "surface-variant": "#2e3637",
                    "surface-tint": "#00dbe7",
                    "surface-container-high": "#232b2c",
                    "on-tertiary-fixed-variant": "#554500",
                    "tertiary": "#fff6e4",
                    "surface": "#0d1515",
                    "secondary-fixed": "#d9e2ff",
                    "on-surface": "#dce4e4",
                    "tertiary-fixed-dim": "#e8c423",
                    "inverse-surface": "#dce4e4",
                    "primary-fixed": "#74f5ff",
                    "surface-dim": "#0d1515",
                    "secondary-fixed-dim": "#afc6ff",
                    "on-secondary-container": "#f8f8ff",
                    "tertiary-container": "#fed83a",
                    "background": "#0d1515",
                    "inverse-on-surface": "#2a3232",
                    "outline": "#849495",
                    "on-secondary": "#002d6d",
                    "surface-container-lowest": "#080f10",
                    "on-error": "#690005",
                    "surface-container-highest": "#2e3637",
                    "on-error-container": "#ffdad6",
                    "on-secondary-fixed-variant": "#004299",
                    "on-tertiary-fixed": "#221b00",
                    "on-primary": "#00363a",
                    "on-tertiary": "#3b2f00",
                    "primary-fixed-dim": "#00dbe7",
                    "on-tertiary-container": "#725e00",
                    "secondary": "#afc6ff",
                    "inverse-primary": "#00696f",
                    "error-container": "#93000a"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "spacing": {
                    "unit": "8px",
                    "stack-md": "24px",
                    "stack-lg": "48px",
                    "container-padding-desktop": "40px",
                    "container-padding-mobile": "20px",
                    "gutter": "24px",
                    "stack-sm": "12px"
            },
            "fontFamily": {
                    "label-lg": ["Hanken Grotesk"],
                    "body-md": ["Hanken Grotesk"],
                    "headline-lg": ["Hanken Grotesk"],
                    "display-lg": ["Hanken Grotesk"],
                    "label-md": ["Hanken Grotesk"],
                    "headline-lg-mobile": ["Hanken Grotesk"],
                    "body-lg": ["Hanken Grotesk"],
                    "headline-md": ["Hanken Grotesk"]
            },
            "fontSize": {
                    "label-lg": ["14px", {"lineHeight": "20px", "letterSpacing": "0.05em", "fontWeight": "600"}],
                    "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                    "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                    "label-md": ["12px", {"lineHeight": "16px", "fontWeight": "500"}],
                    "headline-lg-mobile": ["28px", {"lineHeight": "36px", "fontWeight": "600"}],
                    "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                    "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}]
            }
          },
        },
      }
    </script>
<style>
        body {
            background-color: #0d1515;
            color: #dce4e4;
            font-family: 'Hanken Grotesk', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            border-left: 1px solid rgba(255, 255, 255, 0.15);
        }
        .cyan-glow {
            box-shadow: 0 0 30px rgba(0, 219, 231, 0.15);
        }
        .text-glow {
            text-shadow: 0 0 10px rgba(0, 219, 231, 0.4);
        }
        .pulse-slow {
            animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .7; }
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background selection:bg-primary-container/30">
<!-- Top AppBar -->
<header class="bg-surface/60 backdrop-blur-xl dark:bg-surface-container/60 flex justify-between items-center px-container-padding-mobile h-16 w-full z-50 sticky top-0 border-b border-white/10 shadow-lg shadow-primary/5">
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-primary-fixed-dim hover:bg-white/5 transition-colors p-2 rounded-full active:scale-95 duration-150">menu</button>
<h1 class="font-display-lg text-headline-md tracking-tighter text-primary-fixed-dim drop-shadow-[0_0_10px_rgba(0,219,231,0.4)]">MotorEcho</h1>
</div>
<div class="w-10 h-10 rounded-full overflow-hidden border border-primary-fixed-dim/30">
<img alt="Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD41GWsMygwOxSLZcXZI8eFYacMgY_pZjQ5pEwUgFEoUW_BasW6SgjlNOXdKY7LlFJNr8sSPY_P0Uu5AfLHIwWqIL_p_v22PwA1ygWIBItWfP1nZY0A6MRxyiwlwIPgPXC_YFB_FOsTjL1RRtegfZ67dqTttwOicwRJgUdEvJ4YYBPZ-3B4RfVLDyB6iro-OHNekjb6zxxmssWkXI8aHFXokSsIBmXC0xwNeDozpV6gDckOSfMLiYBaa55bP1fa_jCca8SHYxFuWvy8"/>
</div>
</header>
<main class="max-w-5xl mx-auto px-container-padding-mobile md:px-container-padding-desktop py-stack-sm pb-32">
<!-- Premium 3D-style Hero Card -->
<section class="mt-4 relative group">
<div class="glass-card rounded-[2rem] p-6 md:p-10 relative overflow-hidden cyan-glow">
<!-- Background ambient light -->
<div class="absolute -top-24 -right-24 w-64 h-64 bg-primary-fixed-dim/10 rounded-full blur-[80px]"></div>
<div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
<div class="w-full md:w-1/2">
<div class="flex items-center gap-2 mb-2">
<span class="bg-primary-container/20 text-primary-fixed-dim text-label-md font-label-md px-3 py-1 rounded-full border border-primary-fixed-dim/20 uppercase tracking-widest">Active Vehicle</span>
</div>
<h2 class="font-display-lg text-headline-lg md:text-display-lg text-on-surface mb-2">2022 Porsche 911 GT3</h2>
<div class="flex flex-wrap gap-4 text-on-surface-variant font-body-md text-body-md">
<div class="flex items-center gap-1">
<span class="material-symbols-outlined text-primary-fixed-dim text-[18px]">fingerprint</span>
<span>VIN: WP0ZZZ...</span>
</div>
<div class="flex items-center gap-1">
<span class="material-symbols-outlined text-primary-fixed-dim text-[18px]">speed</span>
<span>12,400 mi</span>
</div>
</div>
<div class="flex gap-4 mt-8">
<button class="bg-gradient-to-r from-primary-fixed-dim to-secondary-container text-on-primary-fixed px-6 py-3 rounded-xl font-label-lg text-label-lg flex items-center gap-2 transition-transform active:scale-95 shadow-lg shadow-primary-container/20">
<span class="material-symbols-outlined">edit</span>
                                Edit Vehicle
                            </button>
<button class="glass-card px-6 py-3 rounded-xl font-label-lg text-label-lg text-primary border border-primary/20 hover:bg-white/5 transition-all">
<span class="material-symbols-outlined align-middle mr-1">add</span>
                                Add New
                            </button>
</div>
</div>
<div class="w-full md:w-1/2 flex justify-center relative">
<!-- Vehicle Image Placeholder -->
<div class="relative w-full max-w-sm aspect-[4/3] flex items-center justify-center">
<div class="absolute inset-0 bg-primary-fixed-dim/5 rounded-full blur-3xl pulse-slow"></div>
<img alt="Porsche 911 GT3" class="w-full h-auto drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] transform -scale-x-100 rotate-[-5deg] group-hover:rotate-0 transition-transform duration-700" data-alt="A side-profile high-performance 2022 Porsche 911 GT3 in a deep metallic grey color, parked in a minimalist, dimly lit concrete studio. The lighting is dramatic and cool-toned, with cyan neon accents reflecting off the car's sleek aerodynamic curves and rear wing. The atmosphere is premium and technical, evoking a sense of engineering precision and power. High-resolution digital photography with cinematic focus." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDmxXm_TEH8lbXaMHu3jaNkrxyH1UmCyXnxeJ7kasdSDX60mTW5Tm_vIlI0LNzlWTuvfWogPlN2Nhs6Br_Iklbap_xwTx5vEHsYvvyIkJy7zLlVh7ESvfAQgXjcIWVDdrQFCPdgh2g4kgjH6ur4DlHynWDe8PSN-lIXUVRAFKB0blagTtIKZybMLL9p-Y6gVNU8Isx0NdiIAUA-A2mvLBvjpCU0Kx4vFB2Y9iAh6FssLr6oXsrIa6H5QU_uffr9SWaIgnGS0tuAjHC_"/>
</div>
</div>
</div>
</div>
</section>
<!-- Bento Grid Stats Section -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter mt-stack-md">
<!-- Health Chart -->
<section class="md:col-span-8 glass-card rounded-3xl p-6 flex flex-col">
<div class="flex justify-between items-center mb-6">
<div>
<h3 class="font-headline-md text-headline-md text-on-surface">Health Statistics</h3>
<p class="text-on-surface-variant text-body-md font-body-md">Engine &amp; System Performance over time</p>
</div>
<select class="bg-surface-variant border-none rounded-lg text-label-md font-label-md text-primary-fixed-dim focus:ring-primary-fixed-dim">
<option>Last 6 Months</option>
<option>Last Year</option>
</select>
</div>
<div class="flex-grow flex items-end gap-2 h-48 px-2 relative">
<!-- Simple Visual Chart using Tailwind -->
<div class="flex-1 bg-primary-fixed-dim/10 rounded-t-lg h-[60%] transition-all hover:bg-primary-fixed-dim/30 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">82%</div>
</div>
<div class="flex-1 bg-primary-fixed-dim/10 rounded-t-lg h-[75%] transition-all hover:bg-primary-fixed-dim/30 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">88%</div>
</div>
<div class="flex-1 bg-primary-fixed-dim/10 rounded-t-lg h-[85%] transition-all hover:bg-primary-fixed-dim/30 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">94%</div>
</div>
<div class="flex-1 bg-primary-fixed-dim/10 rounded-t-lg h-[80%] transition-all hover:bg-primary-fixed-dim/30 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">91%</div>
</div>
<div class="flex-1 bg-primary-fixed-dim/10 rounded-t-lg h-[92%] transition-all hover:bg-primary-fixed-dim/30 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">98%</div>
</div>
<div class="flex-1 bg-primary-container/40 rounded-t-lg h-[98%] transition-all hover:bg-primary-container/60 relative group">
<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-primary-container text-on-primary-container text-[10px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity">99.2%</div>
</div>
<!-- Label Overlay -->
<div class="absolute bottom-0 left-0 right-0 flex justify-between px-2 translate-y-6 text-on-surface-variant font-label-md text-label-md">
<span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span>
</div>
</div>
</section>
<!-- Maintenance Status -->
<section class="md:col-span-4 glass-card rounded-3xl p-6 flex flex-col justify-between border-primary-fixed-dim/20">
<div>
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-tertiary-fixed-dim">build_circle</span>
<h3 class="font-headline-md text-headline-md text-on-surface">Service</h3>
</div>
<p class="text-on-surface-variant text-body-md font-body-md">Next scheduled maintenance in:</p>
<div class="my-4">
<span class="text-display-lg font-display-lg text-primary-fixed-dim text-glow">3,200</span>
<span class="text-headline-md font-headline-md text-on-surface-variant ml-2">miles</span>
</div>
</div>
<div class="w-full bg-white/10 h-2 rounded-full overflow-hidden">
<div class="bg-tertiary-fixed-dim h-full" style="width: 68%;"></div>
</div>
<div class="mt-6">
<button class="w-full py-3 rounded-xl border border-primary/20 text-primary font-label-lg text-label-lg hover:bg-primary/5 transition-colors">Book Service</button>
</div>
</section>
</div>
<!-- Detailed Metrics Section -->
<h3 class="font-headline-md text-headline-md text-on-surface mt-stack-lg mb-stack-sm px-2">Analysis Metrics</h3>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-gutter">
<!-- Spark Plugs -->
<div class="glass-card rounded-2xl p-5 border-l-4 border-l-primary-fixed-dim">
<div class="flex justify-between items-start mb-4">
<span class="material-symbols-outlined text-primary-fixed-dim text-3xl">electric_bolt</span>
<span class="text-primary-fixed-dim font-label-lg text-label-lg">98%</span>
</div>
<h4 class="text-on-surface font-headline-md text-headline-md mb-1">Spark Plugs</h4>
<p class="text-on-surface-variant text-label-md font-label-md uppercase tracking-wide">Excellent</p>
</div>
<!-- Pistons -->
<div class="glass-card rounded-2xl p-5 border-l-4 border-l-primary-fixed-dim">
<div class="flex justify-between items-start mb-4">
<span class="material-symbols-outlined text-primary-fixed-dim text-3xl">settings_input_component</span>
<span class="text-primary-fixed-dim font-label-lg text-label-lg">94%</span>
</div>
<h4 class="text-on-surface font-headline-md text-headline-md mb-1">Pistons</h4>
<p class="text-on-surface-variant text-label-md font-label-md uppercase tracking-wide">Optimal</p>
</div>
<!-- Exhaust -->
<div class="glass-card rounded-2xl p-5 border-l-4 border-l-tertiary-fixed-dim">
<div class="flex justify-between items-start mb-4">
<span class="material-symbols-outlined text-tertiary-fixed-dim text-3xl">air</span>
<span class="text-tertiary-fixed-dim font-label-lg text-label-lg">82%</span>
</div>
<h4 class="text-on-surface font-headline-md text-headline-md mb-1">Exhaust</h4>
<p class="text-on-surface-variant text-label-md font-label-md uppercase tracking-wide">Stable</p>
</div>
<!-- Alternator -->
<div class="glass-card rounded-2xl p-5 border-l-4 border-l-primary-fixed-dim">
<div class="flex justify-between items-start mb-4">
<span class="material-symbols-outlined text-primary-fixed-dim text-3xl">bolt</span>
<span class="text-primary-fixed-dim font-label-lg text-label-lg">96%</span>
</div>
<h4 class="text-on-surface font-headline-md text-headline-md mb-1">Alternator</h4>
<p class="text-on-surface-variant text-label-md font-label-md uppercase tracking-wide">High Efficient</p>
</div>
</div>
</main>
<!-- Bottom Navigation Bar -->
<nav class="bg-surface-container-lowest/80 backdrop-blur-2xl dark:bg-surface-container-lowest/80 fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-2 pb-safe border-t border-white/10 shadow-[0_-8px_30px_rgba(0,0,0,0.5)] rounded-t-xl">
<a class="flex flex-col items-center justify-center text-primary-fixed shadow-[0_-15px_30px_-10px_rgba(0,242,255,0.3)] bg-primary-container/10 rounded-full p-2 transform scale-110 duration-200" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">directions_car</span>
<span class="font-label-md text-label-md">Garage</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant/60 hover:text-primary transition-all duration-300" href="#">
<span class="material-symbols-outlined">mic</span>
<span class="font-label-md text-label-md">Scan</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant/60 hover:text-primary transition-all duration-300" href="#">
<span class="material-symbols-outlined">analytics</span>
<span class="font-label-md text-label-md">Analysis</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant/60 hover:text-primary transition-all duration-300" href="#">
<span class="material-symbols-outlined">history</span>
<span class="font-label-md text-label-md">History</span>
</a>
</nav>
<script>
        // Simple interactivity for the cards
        document.querySelectorAll('.glass-card').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.borderColor = 'rgba(0, 219, 231, 0.3)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.borderColor = 'rgba(255, 255, 255, 0.1)';
            });
        });
    </script>
</body></html>